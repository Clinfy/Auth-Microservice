#URI for database connection
DATABASE_HOST=

#Uri for RabbitMQ
RABBITMQ_URL=

#Uri for Redis
REDIS_URL=

#Port for microservice
PORT=

#Name of the app
APP_NAME=

#URL for frontend
FRONTEND_URL=

# HMAC secret for API key fingerprinting (256-bit key)
# Generate with: openssl rand -hex 32
HMAC_SECRET=

#JWT secret sign
JWT_AUTH_SECRET=
JWT_REFRESH_SECRET=

#JWT expiration times
JWT_AUTH_EXPIRES_IN=
JWT_REFRESH_EXPIRES_IN=

#Reset password expiration time
RESET_PASSWORD_EXPIRES_IN=

#Metrics
METRICS_ENABLED=
# ---------- COOKIE / CORS CONFIGS -----------------
# Cookie domain (e.g., .mydomain.com). If not defined, the request domain is used.
COOKIE_DOMAIN=

# Cookie "secure" flag. False only for local development without HTTPS.

COOKIE_SECURE=true
# Allowed origins for CORS (comma-separated). Required for the browser to send cookies.
CORS_ORIGIN=http://localhost:3001
