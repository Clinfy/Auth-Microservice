#URI for database connection
DATABASE_HOST=

#Uri for RabbitMQ
RABBITMQ_URL=

#Uri for Redis
REDIS_URL=

#Port for microservice
PORT=

#Name of the app
APP_NAME=

#URL for frontend
FRONTEND_URL=

#JWT secret sign
JWT_AUTH_SECRET=
JWT_REFRESH_SECRET=

#JWT expiration times
JWT_AUTH_EXPIRES_IN=
JWT_REFRESH_EXPIRES_IN=

#Reset password expiration time
RESET_PASSWORD_EXPIRES_IN=

#Metrics
METRICS_ENABLED=
# ---------- COOKIE / CORS CONFIGS -----------------
# Dominio de las cookies (ej: .midominio.com). Si no se define, se usa el dominio del request.
COOKIE_DOMAIN=
# Flag "secure" de las cookies. false solo para desarrollo local sin HTTPS.
COOKIE_SECURE=true
# Origenes permitidos para CORS (comma-separated). Requerido para que el navegador envie cookies.
CORS_ORIGIN=http://localhost:3001
