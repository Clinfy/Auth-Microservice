@startuml README Inter-Service Auth
skinparam backgroundColor white
skinparam sequenceArrowThickness 2

actor Browser as browser
participant "Other-MS" as other
participant "Auth-MS\n(MicroserviceGuard)" as auth
database "Redis" as redis

browser -> other : Request\nCookie: auth_token
activate other

other -> other : Extract token from cookie

other -> auth : x-api-key: <service_key>\nAuthorization: Bearer <user_token>
activate auth
auth -> auth : 1. Validate API key (HMAC-SHA256)
auth -> auth : 2. Validate Bearer JWT
auth -> redis : Load session
auth --> other : {id, email, person_id, session_id}
deactivate auth

other --> browser : Response
deactivate other
@enduml
