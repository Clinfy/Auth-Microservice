@startuml Password Reset Flow
skinparam backgroundColor white
skinparam sequenceArrowThickness 2

actor User as user
participant "UsersController" as ctrl
participant "UsersService" as svc
participant "JwtService" as jwt
queue "RabbitMQ\n(Email Queue)" as rmq
participant "Email Service" as email
database "PostgreSQL" as db

== Step 1: Request Password Reset ==

user -> ctrl : POST /users/forgot-password\n{email}
activate ctrl
ctrl -> svc : forgotPassword(email)
activate svc

svc -> db : Find user by email
activate db
db --> svc : UserEntity
deactivate db

svc -> jwt : Generate time-limited\nreset token
activate jwt
jwt --> svc : resetToken
deactivate jwt

svc -> rmq : Publish email request\n(password reset link with token)
activate rmq
rmq --> email : Deliver email
deactivate rmq

svc --> ctrl
deactivate svc
ctrl --> user : {message: "Reset email sent"}
deactivate ctrl

== Step 2: Reset Password ==

user -> ctrl : POST /users/reset-password?token=<token>\n{newPassword}
activate ctrl
ctrl -> svc : resetPassword(token, newPassword)
activate svc

svc -> jwt : Validate reset token
activate jwt
jwt --> svc : payload (email)
deactivate jwt

svc -> db : Update password (bcrypt hash)
activate db
db --> svc
deactivate db

svc --> ctrl
deactivate svc
ctrl --> user : {message: "Password reset successful"}
deactivate ctrl

note right of user
  No cookies are involved.
  The token is passed as a
  query parameter.
end note
@enduml
