    "panels": [
        {
            "title": "Requests Per Second (by endpoint)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": "PBFA97CFB590B2093"
            },
            "targets": [
                {
                    "expr": "sum(rate(auth_http_requests_total[5m])) by (route, method)",
                    "legendFormat": "{{method}} {{route}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10
                    }
                }
            }
        },
        {
